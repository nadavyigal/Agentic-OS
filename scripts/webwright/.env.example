# Webwright environment variables — copy to .env and fill in values
# Never commit .env

# Required: Anthropic API key for Webwright's Claude model calls
ANTHROPIC_API_KEY=sk-ant-...

# Safety: set to false only when explicitly targeting a non-staging URL
STAGING_ONLY=true

# Staging URLs for each product
STAGING_URL_RESUMEBUILDER=http://localhost:3000
STAGING_URL_RUNSMART=http://localhost:3001

# Optional: override the model Webwright uses
# WEBWRIGHT_MODEL=claude-sonnet-4-6
